# Azure AD app registration client ID — create at https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
AZURE_CLIENT_ID=your-app-client-id-here

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Telegram chat ID where the agent sends reports (your personal chat with the bot)
TELEGRAM_CHAT_ID=your-telegram-chat-id
