#!/usr/bin/env node
import 'dotenv/config';
import { program } from 'commander';
import { login } from '../src/auth.js';
import { inbox } from '../src/commands/inbox.js';
import { read } from '../src/commands/read.js';
import { send } from '../src/commands/send.js';
import { reply } from '../src/commands/reply.js';
import { del } from '../src/commands/delete.js';
import { move } from '../src/commands/move.js';
import { markRead, markUnread } from '../src/commands/mark.js';
import { folders } from '../src/commands/folders.js';
import { search } from '../src/commands/search.js';
import { sortCommand } from '../src/commands/sort.js';
import { transactions } from '../src/commands/transactions.js';
import { ruleList, ruleAdd, ruleRm, ruleGuardAdd, ruleGuardRm } from '../src/commands/rule.js';
import { unsortCommand } from '../src/commands/unsort.js';
import { reportCommand } from '../src/commands/report.js';
import { rescueScanCommand } from '../src/commands/rescue-scan.js';

program
  .name('email')
  .description('Outlook.com email CLI')
  .version('1.0.0');

program
  .command('login')
  .description('Authenticate with Microsoft account')
  .action(login);

program
  .command('inbox')
  .description('List inbox messages')
  .option('--unread', 'Show unread only')
  .option('-n, --number <count>', 'Number of messages', '20')
  .action(inbox);

program
  .command('read <index>')
  .description('Read a message by its inbox number')
  .action(read);

program
  .command('send')
  .description('Send a new email')
  .requiredOption('--to <address>', 'Recipient email')
  .requiredOption('--subject <subject>', 'Email subject')
  .option('--body <body>', 'Email body', '')
  .action(send);

program
  .command('reply <index>')
  .description('Reply to a message')
  .requiredOption('--body <body>', 'Reply body')
  .action(reply);

program
  .command('delete <index>')
  .description('Delete a message (move to trash)')
  .action(del);

program
  .command('move <index>')
  .description('Move a message to a folder')
  .requiredOption('--to <folder>', 'Destination folder name')
  .action(move);

program
  .command('mark-read <index>')
  .description('Mark a message as read')
  .action(markRead);

program
  .command('mark-unread <index>')
  .description('Mark a message as unread')
  .action(markUnread);

program
  .command('folders')
  .description('List mail folders')
  .action(folders);

program
  .command('search <query>')
  .description('Search emails')
  .option('-n, --number <count>', 'Max results', '20')
  .action(search);

program
  .command('sort')
  .description('Auto-sort inbox emails into folders (watermark-based)')
  .option('--dry-run', 'Classify without moving emails')
  .option('--since <date>', 'Only emails after this date (YYYY-MM-DD)')
  .option('--limit <count>', 'Max emails to process')
  .option('--min-age <hours>', 'Minimum email age in hours before sorting (overrides config)')
  .action(sortCommand);

program
  .command('transactions')
  .description('List recorded transactions')
  .option('-n, --number <count>', 'Number of transactions', '20')
  .action(transactions);

// rule command with subcommands
const rule = program.command('rule').description('Manage sort rules');

rule
  .command('list')
  .description('List all rules and guards')
  .option('--bucket <bucket>', 'Filter by bucket (accounting/notifications/keep)')
  .action(ruleList);

rule
  .command('add')
  .description('Add a new sort rule')
  .requiredOption('--bucket <bucket>', 'Target bucket (accounting/notifications/keep)')
  .requiredOption('--domain <domains...>', 'One or more domains')
  .option('--subject <regex>', 'Subject regex pattern')
  .option('--subject-exclude <regex>', 'Subject regex pattern to exclude from match')
  .option('--ignore-guards', 'Bypass guard word blocking for this rule')
  .option('--note <text>', 'Note for this rule')
  .action(ruleAdd);

rule
  .command('rm <id>')
  .description('Remove a rule by ID')
  .action(ruleRm);

const guard = rule.command('guard').description('Manage guard words');

guard
  .command('add <word>')
  .description('Add a guard word')
  .action(ruleGuardAdd);

guard
  .command('rm <word>')
  .description('Remove a guard word')
  .action(ruleGuardRm);

program
  .command('unsort')
  .description('Move sorted emails back to inbox')
  .option('--sender <address>', 'Filter by sender')
  .option('--rule <id>', 'Filter by rule ID')
  .option('--email-id <id>', 'Filter by specific email ID')
  .option('--since <date>', 'Only emails sorted after this date (ISO)')
  .option('--dry-run', 'Show what would be unsorted without moving')
  .action(unsortCommand);

program
  .command('report')
  .description('Sort activity report')
  .option('--hours <n>', 'Report window in hours', '24')
  .option('--since <date>', 'Report since date (ISO)')
  .option('--live', 'Simulate classification on current inbox')
  .option('--json', 'Output machine-readable JSON')
  .action(reportCommand);

program
  .command('rescue-scan')
  .description('Scan sorted folders for guard-matching emails')
  .option('--since <date>', 'Only emails after this date (YYYY-MM-DD)')
  .option('--folder <name>', 'Scan specific folder (Accounting or Notifications)')
  .action(rescueScanCommand);

program.parse();
